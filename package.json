{
  "name": "stock-analytics-v2",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "check:finmind-secret": "node scripts/sync-finmind-secret.mjs --check-only",
    "check:production": "node scripts/production-health.mjs",
    "check:production:ready": "node scripts/production-health.mjs --require-ready",
    "check:secrets": "node scripts/secrets-doctor.mjs",
    "complete:production": "node scripts/complete-production.mjs",
    "deploy": "pnpm deploy:worker && pnpm deploy:web",
    "deploy:web": "pnpm --filter @stock-analytics/web run deploy",
    "deploy:worker": "pnpm --filter @stock-analytics/worker run deploy",
    "dev": "pnpm --filter @stock-analytics/web dev",
    "migrate:remote": "pnpm --filter @stock-analytics/worker migrate:remote",
    "sync:finmind-secret": "node scripts/sync-finmind-secret.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
